--  TAB 1 — DUMBBELL
-- ═══════════════════════════
local MainTab = Window:CreateTab("🏋️ Dumbbell", 0)

MainTab:CreateSection("Energy")

MainTab:CreateToggle({
    Name         = "Auto Dumbbell 2x",
    CurrentValue = false,
    Flag         = "auto_dumbbell",
    Callback     = function(v)
        running = v
        if running and not loopActive then
            task.spawn(function()
                loopActive = true
                while running do
                    local liftSpeed = LocalPlayer:GetAttribute("LiftSpeed") or 0
                    local cooldown  = 1 / (1 + liftSpeed / 100)
                    EnergyEvent:FireServer(true, 10)
                    task.wait(cooldown)
                end
                loopActive = false
            end)
        end
    end
})

MainTab:CreateSection("Farm")

MainTab:CreateToggle({
    Name         = "Auto Collect Money",
    CurrentValue = false,
    Flag         = "auto_collect",
    Callback     = function(v)
        collecting = v
        if collecting and not collectLoop then
            task.spawn(function()
                collectLoop = true
                while collecting do
                    doCollect()
                    task.wait(1)
                end
                collectLoop = false
            end)
        end
    end
})

MainTab:CreateSection("Combat")

MainTab:CreateButton({
    Name     = "💀 Kill Block",
    Callback = function()
        isKillBlock = true
        DamageEvent:FireServer(800000000000000)
        isKillBlock = false
    end
})

MainTab:CreateSection("Protection")

MainTab:CreateToggle({
    Name         = "Block Debuff",
    CurrentValue = false,
    Flag         = "block_debuff",
    Callback     = function(v)
        blockDebuff = v
    end
})

MainTab:CreateToggle({
    Name         = "God Mode",
    CurrentValue = false,
    Flag         = "god_mode",
    Callback     = function(v)
        blockDamage = v
    end
})

-- ═══════════════════════════
--  TAB 2 — BASE
-- ═══════════════════════════
local BaseTab = Window:CreateTab("🏠 Base", 0)

BaseTab:CreateSection("Upgrade")

BaseTab:CreateToggle({
    Name         = "Auto Upgrade Base",
    CurrentValue = false,
    Flag         = "auto_upgrade",
    Callback     = function(v)
        autoUpgrade = v
        if autoUpgrade and not upgradeLoop then
            task.spawn(function()
                upgradeLoop = true
                while autoUpgrade do
                    local slots = LocalPlayer:GetAttribute("Slots") or 0
                    if not BaseUpgradeModule.canBuy(slots) then
                        autoUpgrade = false
                        break
                    end
                    local cost = BaseUpgradeModule.getCost(slots)
                    local cash = LocalPlayer.leaderstats.Cash.Value
                    if cash >= cost then
                        BaseUpgradeEvent:FireServer()
                    end
                    task.wait(0.5)
                end
                upgradeLoop = false
            end)
        end
    end
})

BaseTab:CreateSection("Rebirth")

BaseTab:CreateToggle({
    Name         = "Auto Rebirth",
    CurrentValue = false,
    Flag         = "auto_rebirth",
    Callback     = function(v)
        autoRebirth = v
        if autoRebirth and not rebirthLoop then
            task.spawn(function()
                rebirthLoop = true
                while autoRebirth do
                    RebirthEvent:FireServer()
                    task.wait(0.5)
                end
                rebirthLoop = false
            end)
        end
    end
})

-- ═══════════════════════════
--  TAB 3 — BLOCKS
-- ═══════════════════════════
local BlocksTab = Window:CreateTab("🎲 Blocks", 0)

BlocksTab:CreateSection("Auto Buy")

BlocksTab:CreateToggle({
    Name         = "Auto Buy Lucky Blocks",
    CurrentValue = false,
    Flag         = "auto_buy_blocks",
    Callback     = function(v)
        autoBuyBlocks = v
        if autoBuyBlocks and not buyBlocksLoop then
            task.spawn(function()
                buyBlocksLoop = true
                while autoBuyBlocks do
                    local luckyBlocks = LocalPlayer:FindFirstChild("LuckyBlocks")
                    local cash        = LocalPlayer.leaderstats.Cash.Value
                    local allOwned    = true

                    for blockName, blockData in pairs(LuckyBlocksModule) do
                        if blockName == "Basic Block" then continue end
                        local owned = luckyBlocks and luckyBlocks:GetAttribute(blockName:gsub(" ", "_")) == true
                        if not owned then
                            allOwned = false
                            if cash >= blockData.Price then
                                BuyBlockEvent:FireServer(blockName)
                                task.wait(0.5)
                                cash = LocalPlayer.leaderstats.Cash.Value
                            end
                        end
                    end

                    if allOwned then
                        autoBuyBlocks = false
                        break
                    end
                    task.wait(1)
                end
                buyBlocksLoop = false
            end)
        end
    end
})

BlocksTab:CreateSection("Auto Buy Shovels")

BlocksTab:CreateToggle({
    Name         = "Auto Buy Shovels",
    CurrentValue = false,
    Flag         = "auto_buy_shovels",
    Callback     = function(v)
        autoBuyShovels = v
        if autoBuyShovels and not buyShovelsLoop then
            task.spawn(function()
                buyShovelsLoop = true
                while autoBuyShovels do
                    local shovels  = LocalPlayer:FindFirstChild("Shovels")
                    local cash     = LocalPlayer.leaderstats.Cash.Value
                    local allOwned = true

                    for shovelName, shovelData in pairs(ShovelsModule) do
                        local owned = shovels and shovels:GetAttribute(shovelName:gsub(" ", "_")) == true
                        if not owned then
                            allOwned = false
                            if cash >= shovelData.Price then
                                BuyShovelEvent:FireServer(shovelName)
                                task.wait(0.5)
                                cash = LocalPlayer.leaderstats.Cash.Value
                            end
                        end
                    end

                    if allOwned then
                        autoBuyShovels = false
                        break
                    end
                    task.wait(1)
                end
                buyShovelsLoop = false
            end)
        end
    end
})