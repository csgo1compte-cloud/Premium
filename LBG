local Ui = loadstring(game:HttpGet("https://raw.githubusercontent.com/csgo1compte-cloud/RayVoid/refs/heads/main/RayVoid"))()
Ui:SetScriptName("Lucky-Block-Game")
Ui:SetPremium(true)

local RS          = game:GetService("ReplicatedStorage")
local LocalPlayer = game:GetService("Players").LocalPlayer

local EnergyEvent       = RS:WaitForChild("Remotes"):WaitForChild("EnergyEvent")
local DoorEvent         = RS:WaitForChild("Remotes"):WaitForChild("DoorEvent")
local DamageEvent       = RS:WaitForChild("Remotes"):WaitForChild("DamageEvent")
local BaseUpgradeEvent  = RS:WaitForChild("Remotes"):WaitForChild("BaseUpgradeEvent")
local BaseUpgradeModule = require(RS:WaitForChild("BaseUpgradeModule"))
local RebirthEvent      = RS:WaitForChild("Remotes"):WaitForChild("RebirthEvent")
local BuyBlockEvent     = RS:WaitForChild("Remotes"):WaitForChild("BuyBlockEvent")
local LuckyBlocksModule = require(RS:WaitForChild("LuckyBlocksModule"))
local BuyShovelEvent    = RS:WaitForChild("Remotes"):WaitForChild("BuyShovelEvent")
local ShovelsModule     = require(RS:WaitForChild("ShovelsModule"))

-- State
local running      = false
local loopActive   = false
local blockDebuff  = false
local blockDamage  = false
local collecting   = false
local collectLoop  = false
local isKillBlock  = false
local autoUpgrade  = false
local upgradeLoop  = false
local autoRebirth   = false
local rebirthLoop   = false
local autoBuyBlocks  = false
local buyBlocksLoop  = false
local autoBuyShovels = false
local buyShovelsLoop = false

-- Hook
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer" then
        if blockDebuff and self == DoorEvent then
            local args  = {...}
            local value = args[1]
            local op    = args[2]
            if type(value) == "number" and type(op) == "string" then
                if (op == "mul" and value < 1) or
                   (op == "div" and value > 1) or
                   (op == "add" and value < 0) then
                    return
                end
            end
        end
        if blockDamage and self == DamageEvent then
            if not isKillBlock then
                return
            end
        end
    end
    return oldNamecall(self, ...)
end)

-- Fonction pour trouver la base du joueur
local function getPlayerBase()
    for _, base in ipairs(workspace.Bases:GetChildren()) do
        if base:GetAttribute("Owner") == LocalPlayer.Name then
            return base
        end
    end
    return nil
end

-- Fonction collect
local function doCollect()
    local base = getPlayerBase()
    if not base then return end

    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    for f = 1, 3 do
        local floor = base:FindFirstChild("Floor" .. f)
        if not floor then continue end

        local platforms = floor:FindFirstChild("Platforms")
        if not platforms then continue end

        for p = 1, 10 do
            local platform = platforms:FindFirstChild(tostring(p))
            if not platform then continue end

            local collect = platform:FindFirstChild("Collect")
            if not collect then continue end

            firetouchinterest(hrp, collect, 0)
            task.wait(0.1)
            firetouchinterest(hrp, collect, 1)
            task.wait(0.1)
        end
    end
    task.wait(60)
end

