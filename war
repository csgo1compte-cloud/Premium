-- ══════════════════════════════════
--  HELPERS
-- ══════════════════════════════════

local function getMyPlot()
    for _, plot in ipairs(workspace.MilitaryMap.PlayerPlots:GetChildren()) do
        local label = plot:FindFirstChild("UI")
            and plot.UI:FindFirstChild("BillboardGui")
            and plot.UI.BillboardGui:FindFirstChild("Holder")
            and plot.UI.BillboardGui.Holder:FindFirstChild("PlayerName")
        if label and label.Text:find(LocalPlayer.Name) then
            return plot
        end
    end
end

local function getStock(itemName)
    local frame = LocalPlayer.PlayerGui.MainUI.Fullscreen.BuyUI.ItemsGrid:FindFirstChild(itemName)
    if not frame then return 0 end
    local stock = frame:FindFirstChild("Stock")
    if not stock then return 0 end
    if stock.Text == "Out of Stock!" then return 0 end
    local n = stock.Text:match("Stock x(%d+)")
    return tonumber(n) or 0
end

local function buyItem(itemName)
    local shop = itemToShop[itemName]
    if not shop then return end
    local count = getStock(itemName)
    if count <= 0 then return end
    for _ = 1, count do
        Event:FireServer({
            { item = itemName, shop = shop },
            "#"
        })
        task.wait(0.15)
    end
end

local function collectFarms()
    local plot = getMyPlot()
    if not plot then return end
    for _, building in ipairs(plot.Plot.Buildings:GetChildren()) do
        if building:GetAttribute("type") == "Farm" then
            Event:FireServer({ building, ";" })
            task.wait(0.1)
        end
    end
end

