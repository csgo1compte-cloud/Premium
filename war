local selectedItems  = {}
local autoBuyEnabled = false
local collectEnabled = false

-- ══════════════════════════════════
--  UI
-- ══════════════════════════════════

local Window = VoidUI:CreateWindow({ Name = "Military Map" })
local Tab = Window:CreateTab("Farm")

Tab:CreateSection("Collect & Sell")

Tab:CreateToggle({
    Name         = "Auto Collect",
    CurrentValue = false,
    Flag         = "AutoCollect",
    Callback     = function(state)
        collectEnabled = state
        if not state then return end
        task.spawn(function()
            while collectEnabled do
                collectFarms()
                task.wait(120)
            end
        end)
    end,
})

Tab:CreateSection("Auto Buy")

Tab:CreateToggle({
    Name         = "Auto Buy",
    CurrentValue = false,
    Flag         = "AutoBuy",
    Callback     = function(state)
        autoBuyEnabled = state
        if not state then return end
        task.spawn(function()
            while autoBuyEnabled do
                for itemName, _ in pairs(selectedItems) do
                    buyItem(itemName)
                    task.wait(0.1)
                end
                task.wait(120)
            end
        end)
    end,
})

local groups = {}
for _, group in ipairs(shopItems) do
    local items = {}
    for _, itemName in ipairs(group.Items) do
        local frame = LocalPlayer.PlayerGui.MainUI.Fullscreen.BuyUI.ItemsGrid:FindFirstChild(itemName)
        local img = frame and frame:FindFirstChild("Template") and frame.Template:FindFirstChild("RenderImage")
        table.insert(items, { Name = itemName, Icon = img and img.Image or "" })
    end
    table.insert(groups, { Label = group.Label, Items = items })
end

Tab:CreateFilteredCardGrid({
    Groups   = groups,
    Columns  = 3,
    Callback = function(selected)
        selectedItems = selected
    end,
})
