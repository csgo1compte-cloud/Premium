local ShopTab = Window:CreateTab("Shop", 4483362458)

local Event     = game:GetService("ReplicatedStorage").Remotes.HatchEgg
local shopFrame = player.PlayerGui.EggShopGui.Frame.Holder.ScrollingFrame

local suffixes = { K=1e3, M=1e6, B=1e9, T=1e12, Qi=1e15, Qa=1e18, Sx=1e21 }

local function parsePrice(str)
    local num, suf = str:match("%$([%d%.]+)(%a+)")
    if num and suf then return tonumber(num) * (suffixes[suf] or 1) end
    local plain = str:match("%$([%d%.]+)")
    if plain then return tonumber(plain) end
    return 0
end

local function getEggs()
    local eggs = {}
    for _, child in ipairs(shopFrame:GetChildren()) do
        if child:IsA("ImageLabel") and not child.Name:match("Template") then
            local nameLabel  = child:FindFirstChild("NameLabel")
            local priceLabel = child:FindFirstChild("BuyButton") and child.BuyButton:FindFirstChild("Price")
            local stockLabel = child:FindFirstChild("StockLabel")
            if nameLabel and priceLabel and stockLabel
                and priceLabel.Text ~= "Label" then
                table.insert(eggs, {
                    name       = nameLabel.Text,
                    remoteName = child.Name:gsub("Egg_", ""),
                    price      = parsePrice(priceLabel.Text),
                    stock      = stockLabel.Text,
                })
            end
        end
    end
    table.sort(eggs, function(a, b) return a.price < b.price end)
    return eggs
end

ShopTab:CreateSection("Egg Shop")

local eggs = getEggs()
local eggNames = {}
for _, egg in ipairs(eggs) do
    table.insert(eggNames, egg.name)
end

local selectedEggs = {}

ShopTab:CreateMultiToggle({
    Label    = "Select eggs to buy",
    Options  = eggNames,
    Callback = function(states) selectedEggs = states end,
})

local autoBuy = false


ShopTab:CreateToggle({
    Name         = "Auto Buy",
    CurrentValue = false,
    Callback     = function(val)
        autoBuy = val
        if autoBuy then
            task.spawn(function()
                while autoBuy do
                    local currentEggs = getEggs()
                    local eggMap = {}
                    for _, egg in ipairs(currentEggs) do
                        eggMap[egg.name] = egg
                    end
                    for name, enabled in pairs(selectedEggs) do
                        if enabled then
                            local egg = eggMap[name]
                            if egg then
                                local stock = tonumber(egg.stock:match("%d+"))
                                if stock and stock > 0 then
                                    Event:InvokeServer(egg.remoteName, 9999)
                                    task.wait(0.5)
                                end
                            end
                        end
                    end
                    task.wait(120)
                end
            end)
        end
    end,
})
