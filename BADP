local function getChar()
    local char = lp.Character
    return char, char and char:FindFirstChildOfClass("Humanoid"), char and char:FindFirstChild("HumanoidRootPart")
end

local function parseMoney(str)
    str = str:gsub("%$", ""):gsub(",", "")
    local suffixes = {K=1e3, M=1e6, B=1e9, T=1e12, Qi=1e15}
    for suffix, mult in pairs(suffixes) do
        local n = str:match("^([%d%.]+)"..suffix.."$")
        if n then return tonumber(n) * mult end
    end
    return tonumber(str) or 0
end

local function parseStock(str)
    local n = str:match("[xX](%d+)")
    return tonumber(n) or 0
end

-- ══════════════════════════════
--  PEN COLLECT
-- ══════════════════════════════

local function getMyPens()
    local pens = {}
    local userId = lp.UserId
    for _, pen in ipairs(workspace.Gameplay.Bin:GetChildren()) do
        if pen.Name:match("^[Pp]en_%d+$") and pen:GetAttribute("Owner") == userId then
            local cashCollect = pen:FindFirstChild("Gameplay") and pen.Gameplay:FindFirstChild("CashCollect")
            if cashCollect then
                table.insert(pens, {
                    Pen         = pen,
                    CashCollect = cashCollect,
                })
            end
        end
    end
    return pens
end

task.spawn(function()
    while true do
        if not penActive then
            task.wait(0.5)
            continue
        end

        local _, humanoid, hrp = getChar()
        if not humanoid or not hrp then
            task.wait(1)
            continue
        end

        local pens = getMyPens()
        if #pens == 0 then
            task.wait(5)
            continue
        end

        for _, penData in ipairs(pens) do
            if not penActive then break end

            if penData.Pen:GetAttribute("Cash") == 0 then continue end

            local target = penData.CashCollect.Position
            humanoid:MoveTo(target)

            local elapsed = 0
            while penActive and elapsed < 6 do
                local h = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if not h then break end
                if (h.Position - target).Magnitude < 4 then break end
                task.wait(0.1)
                elapsed += 0.1
            end

            task.wait(0.25)
        end

        local waited = 0
        while penActive and waited < 120 do
            task.wait(1)
            waited += 1
        end
    end
end)

-- ══════════════════════════════
--  CASH DROP COLLECT
-- ══════════════════════════════

task.spawn(function()
    while true do
        task.wait(0.2)
        if not cashActive then continue end

        local _, humanoid, hrp = getChar()
        if not humanoid or not hrp then continue end

        local closest = nil
        local closestDist = math.huge

        for _, v in ipairs(workspace:GetChildren()) do
            if v:IsA("BasePart") and v:FindFirstChild("Mesh") then
                local dist = (v.Position - hrp.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = v
                end
            end
        end

        if closest then
            humanoid:MoveTo(closest.Position)
        end
    end
end)

