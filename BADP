--  ANIMAL SHOP
-- ══════════════════════════════

local function getAnimalShopItems()
    local items = {}
    local sf = lp.PlayerGui.AnimalShop.Main.Content.ScrollingFrame
    for _, child in ipairs(sf:GetChildren()) do
        if child.Name == "Template" then
            local ok, name, price, icon, stock = pcall(function()
                local n  = child.Details.NameTxt.Text
                local p  = parseMoney(child.Buttons.BuyCash.Title.Text)
                local ic = child.Icon.Icon.Image
                local s  = parseStock(child.Details.Stock.StockTxt.Text)
                return n, p, ic, s
            end)
            if ok then
                table.insert(items, {
                    Name  = name,
                    Price = price,
                    Icon  = icon,
                    Stock = stock,
                })
            end
        end
    end
    return items
end

local function runAnimalShopBuy()
    local items = getAnimalShopItems()
    for _, item in ipairs(items) do
        if not autoShopActive then break end
        if not selectedAnimals[item.Name] then continue end
        if item.Stock <= 0 then continue end
        for i = 1, item.Stock do
            if not autoShopActive then break end
            pcall(function()
                Event:FireServer("BuyFromAnimalStock", item.Name)
            end)
            task.wait(0.2)
        end
    end
end

task.spawn(function()
    while true do
        task.wait(120)
        if not autoShopActive then continue end
        runAnimalShopBuy()
    end
end)

-- ══════════════════════════════
--  PEN SHOP
-- ══════════════════════════════

local function getPenShopItems()
    local items = {}
    local sf = lp.PlayerGui.PenShop.Main.Content.ScrollingFrame
    for _, pen in ipairs(game:GetService("ReplicatedStorage").Assets.Pens:GetChildren()) do
        if not pen:GetAttribute("InStock") then continue end

        local stock = 0
        for _, child in ipairs(sf:GetChildren()) do
            if child.Name == "Template" then
                local nameTxt = child:FindFirstChild("Details") and child.Details:FindFirstChild("NameTxt")
                if nameTxt and nameTxt.Text == pen:GetAttribute("Name") then
                    stock = parseStock(child.Details.Stock.StockTxt.Text)
                    break
                end
            end
        end

        table.insert(items, {
            Name  = pen:GetAttribute("Name"),
            ID    = pen:GetAttribute("ID"),
            Price = pen:GetAttribute("Price"),
            Icon  = pen:GetAttribute("Icon"),
            Stock = stock,
        })
    end
    return items
end

local function runPenShopBuy()
    local items = getPenShopItems()
    for _, item in ipairs(items) do
        if not autoPenShopActive then break end
        if not selectedPens[item.Name] then continue end
        if item.Stock <= 0 then continue end
        for i = 1, item.Stock do
            if not autoPenShopActive then break end
            pcall(function()
                Event:FireServer("BuyFromPenStock", item.ID)
            end)
            task.wait(0.2)
        end
    end
end

task.spawn(function()
    while true do
        task.wait(120)
        if not autoPenShopActive then continue end
        runPenShopBuy()
    end
end)

-- ══════════════════════════════
--  AUTO PLACE EGG
-- ══════════════════════════════

local function autoPlace()
    local _, humanoid, hrp = getChar()
    if not humanoid or not hrp then return end

    local pens = getMyPens()
    if #pens == 0 then return end

    for _, penData in ipairs(pens) do
        if not autoPlaceActive then break end

        local cap    = penData.Pen:GetAttribute("Capacity") or 0
        local maxCap = penData.Pen:GetAttribute("MaxCapacity") or 0
        if cap >= maxCap then continue end

        -- Rescan backpack avant chaque pen
        local tools = {}
        for _, tool in ipairs(lp.Backpack:GetChildren()) do
            if tool:GetAttribute("Type") == "Egg" then
                table.insert(tools, tool)
            end
        end

        if #tools == 0 then break end

        local target = penData.CashCollect.Position
        humanoid:MoveTo(target)

        local elapsed = 0
        while autoPlaceActive and elapsed < 6 do
            local h = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not h then break end
            if (h.Position - target).Magnitude < 5 then break end
            task.wait(0.1)
            elapsed += 0.1
        end

        for _, tool in ipairs(tools) do
            if not autoPlaceActive then break end

            local c    = penData.Pen:GetAttribute("Capacity") or 0
            local maxC = penData.Pen:GetAttribute("MaxCapacity") or 0
            if c >= maxC then break end

            humanoid:EquipTool(tool)
            task.wait(0.3)

            local prompt = penData.Pen.Gameplay.PlacePrompt:FindFirstChild("PlacePrompt")
            if prompt then
                fireproximityprompt(prompt)
                task.wait(0.5)
            end
        end

        humanoid:UnequipTools()
        task.wait(0.3)
    end
end

task.spawn(function()
    while true do
        task.wait(120)
        if not autoPlaceActive then continue end
        autoPlace()
    end
end)

-- ══════════════════════════════
--  AUTO HATCH EGG
-- ══════════════════════════════

local function autoHatch()
    local _, humanoid, hrp = getChar()
    if not humanoid or not hrp then return end

    local userId = lp.UserId

    for _, obj in ipairs(workspace.Gameplay.Bin:GetChildren()) do
        if not autoHatchActive then break end
        if obj:GetAttribute("Owner") ~= userId then continue end
        if obj:GetAttribute("Type") ~= "Egg" then continue end

        local timePassed  = obj:GetAttribute("TimePassed") or 0
        local timeToHatch = obj:GetAttribute("TimeToHatch") or 0
        if timePassed < timeToHatch then continue end

        local prompt = obj:FindFirstChild("HatchPrompt") and obj.HatchPrompt:FindFirstChild("HatchPrompt")
        if not prompt then continue end

        local target = obj:GetPivot().Position
        humanoid:MoveTo(target)

        local elapsed = 0
        while autoHatchActive and elapsed < 6 do
            local h = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not h then break end
            if (h.Position - target).Magnitude < 5 then break end
            task.wait(0.1)
            elapsed += 0.1
        end

        fireproximityprompt(prompt)
        task.wait(0.5)
    end
end

task.spawn(function()
    while true do
        task.wait(30)
        if not autoHatchActive then continue end
        autoHatch()
    end
end)

